model Conversation {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  bookingId String?  @map("booking_id") @db.Uuid
  booking   Booking? @relation(fields: [bookingId], references: [id])

  participant1 String @map("participant_1") @db.Uuid
  user1        User   @relation("Participant1Conversations", fields: [participant1], references: [id])
  participant2 String @map("participant_2") @db.Uuid
  user2        User   @relation("Participant2Conversations", fields: [participant2], references: [id])

  subject          String? @db.VarChar(255)
  isBookingRelated Boolean @default(false) @map("is_booking_related")

  isActive Boolean @default(true) @map("is_active")

  lastMessageAt      DateTime? @map("last_message_at") @db.Timestamptz
  lastMessagePreview String?   @map("last_message_preview") @db.VarChar(200)

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @default(now()) @map("updated_at") @db.Timestamptz

  messages Message[]

  @@index([participant1])
  @@index([participant2])
  @@index([bookingId])
  @@map("conversations")
}

model Message {
  id             String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  conversationId String       @map("conversation_id") @db.Uuid
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId       String       @map("sender_id") @db.Uuid
  sender         User         @relation(fields: [senderId], references: [id])

  content     String  @db.Text
  contentType String? @default("text") @map("content_type") @db.VarChar(20)

  isRead Boolean   @default(false) @map("is_read")
  readAt DateTime? @map("read_at") @db.Timestamptz

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@index([conversationId])
  @@map("messages")
}
